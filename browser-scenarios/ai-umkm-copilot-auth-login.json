{
    "id":  "ai-umkm-copilot-auth-login",
    "name":  "AI UMKM Copilot Auth Login Flow",
    "description":  "Authenticated login flow for AI UMKM Copilot using credentials from local .env.",
    "continueOnFailure":  false,
    "baseUrl":  "https://ai-umkm-copilot.vercel.app/login",
    "steps":  [
                  {
                      "url":  "https://ai-umkm-copilot.vercel.app/login",
                      "id":  "open-login-page",
                      "type":  "goto",
                      "enabled":  true
                  },
                  {
                      "selector":  "input[type=\u0027email\u0027]",
                      "enabled":  true,
                      "id":  "wait-email-input",
                      "type":  "wait-for-selector",
                      "timeoutMs":  10000
                  },
                  {
                      "selector":  "input[type=\u0027email\u0027]",
                      "valueFromEnv":  "NUSATESTLAB_TEST_EMAIL",
                      "id":  "fill-email",
                      "type":  "fill",
                      "enabled":  true
                  },
                  {
                      "selector":  "input[type=\u0027password\u0027]",
                      "valueFromEnv":  "NUSATESTLAB_TEST_PASSWORD",
                      "id":  "fill-password",
                      "type":  "fill",
                      "enabled":  true
                  },
                  {
                      "selector":  "button[type=\u0027submit\u0027]",
                      "enabled":  true,
                      "id":  "click-login",
                      "type":  "click",
                      "waitAfterMs":  8000
                  },
                  {
                      "selector":  "text=Dashboard",
                      "enabled":  true,
                      "id":  "wait-dashboard-text",
                      "type":  "wait-for-selector",
                      "timeoutMs":  15000
                  },
                  {
                      "enabled":  true,
                      "id":  "expect-dashboard-text",
                      "type":  "expect-text",
                      "text":  "Dashboard"
                  },
                  {
                      "enabled":  true,
                      "id":  "expect-transaction-button",
                      "type":  "expect-text",
                      "text":  "Tambah Transaksi"
                  },
                  {
                      "enabled":  true,
                      "id":  "expect-logout-button",
                      "type":  "expect-text",
                      "text":  "Keluar"
                  }
              ]
}
