{
  "id": "example-homepage",
  "name": "Example.com Homepage Scenario",
  "baseUrl": "https://example.com",
  "viewport": {
    "width": 1365,
    "height": 768
  },
  "maxLinks": 5,
  "continueOnFailure": false,
  "steps": [
    {
      "id": "open-home",
      "type": "goto",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "id": "expect-heading",
      "type": "expect-text",
      "text": "Example Domain"
    },
    {
      "id": "check-links",
      "type": "check-links",
      "maxLinks": 5
    },
    {
      "id": "screenshot-home",
      "type": "screenshot",
      "name": "example-home"
    }
  ]
}
