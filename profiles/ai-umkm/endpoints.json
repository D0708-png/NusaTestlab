{
  "endpoints": [
    {
      "id": "health-check",
      "name": "Health Check",
      "method": "GET",
      "path": "/health",
      "module": "system",
      "requiredRole": "none",
      "description": "Checks whether the target SaaS API is running."
    },
    {
      "id": "auth-me",
      "name": "Current User",
      "method": "GET",
      "path": "/api/auth/me",
      "module": "auth",
      "requiredRole": "owner",
      "description": "Returns the current authenticated user."
    },
    {
      "id": "products-list",
      "name": "Product List",
      "method": "GET",
      "path": "/api/products",
      "module": "inventory",
      "requiredRole": "admin",
      "description": "Returns product list for the current tenant or store."
    },
    {
      "id": "inventory-summary",
      "name": "Inventory Summary",
      "method": "GET",
      "path": "/api/inventory/summary",
      "module": "inventory",
      "requiredRole": "admin",
      "description": "Returns inventory summary."
    },
    {
      "id": "sales-report",
      "name": "Sales Report",
      "method": "GET",
      "path": "/api/reports/sales",
      "module": "reports",
      "requiredRole": "admin",
      "description": "Returns sales report."
    },
    {
      "id": "profit-report",
      "name": "Profit Report",
      "method": "GET",
      "path": "/api/reports/profit",
      "module": "reports",
      "requiredRole": "owner",
      "description": "Returns profit report. Cashier should not be allowed to access this endpoint."
    }
  ]
}
